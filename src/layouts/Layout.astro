---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Spectra — Native IPTV player for macOS',
  description = 'A native macOS player for Xtream Codes IPTV providers. Full EPG guide, movies and series with resume, and rock-solid playback. macOS 14+, free during beta.',
} = Astro.props;

// The only place public/ assets are referenced — keep base-path handling here.
const base = import.meta.env.BASE_URL;
const canonical = new URL(base, Astro.site);
const ogImage = new URL(`${base}og.png`.replace('//', '/'), Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0b0c0e" />

    <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32.png`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-ink-950 text-fg font-sans antialiased">
    <slot />
  </body>
</html>
