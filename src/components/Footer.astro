---
import { Image } from 'astro:assets';
import DownloadButton from './DownloadButton.astro';
import wordmark from '../assets/appglyph.png';
---

<section class="border-t border-line bg-ink-900">
  <div class="mx-auto flex max-w-6xl flex-col items-center px-6 py-20 text-center">
    <h2 class="max-w-2xl text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
      Give your provider the player it deserves.
    </h2>
    <div class="mt-8">
      <DownloadButton size="lg" showFinePrint />
    </div>
  </div>
</section>

<footer class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">
      <Image src={wordmark} alt="Spectra" class="h-5 w-auto opacity-70" densities={[1, 2]} height={20} />
      <div class="flex items-center gap-6 text-sm text-fg-muted">
        <a href="https://github.com/Spectra-Player/releases/releases" class="transition hover:text-fg">Releases</a>
        <span class="text-fg-faint">macOS 14+</span>
      </div>
    </div>
    <p class="mt-8 text-center text-xs leading-relaxed text-fg-faint sm:text-left">
      Spectra is a media player. It does not provide, sell, or host any channels, streams,
      or media content. You connect it to your own IPTV provider subscription using
      credentials they gave you.
    </p>
    <p class="mt-3 text-center text-xs text-fg-faint sm:text-left">© 2026 Spectra</p>
  </div>
</footer>
