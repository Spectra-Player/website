---
import { Image } from 'astro:assets';
import AppWindow from './AppWindow.astro';
import DownloadButton from './DownloadButton.astro';
import heroShot from '../assets/screenshots/epg.png';
---

<section id="top" class="relative overflow-hidden">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="mx-auto flex max-w-6xl flex-col items-center px-6 pt-24 pb-20 text-center sm:pt-28">
    <span class="mb-6 rounded-full border border-line px-3 py-1 text-xs text-fg-muted">
      Free beta — now available
    </span>
    <h1 class="max-w-3xl text-5xl font-semibold tracking-tight text-balance sm:text-6xl">
      IPTV that finally feels at home on your&nbsp;Mac.
    </h1>
    <p class="mt-6 max-w-xl text-lg text-fg-muted text-pretty">
      Spectra is a native macOS player for Xtream Codes providers. A real EPG guide,
      movies and series with resume, and rock-solid playback — talking directly to
      your provider, and no one else.
    </p>
    <div class="mt-8">
      <DownloadButton size="lg" showFinePrint />
    </div>
    <div class="mt-16 w-full max-w-5xl">
      <AppWindow glow>
        <Image
          src={heroShot}
          alt="Spectra's EPG guide: a programme grid with a pinned channel column and now-playing indicator"
          widths={[720, 1100, 1600, 2200]}
          formats={['webp']}
          sizes="(max-width: 1100px) 100vw, 1024px"
          loading="eager"
        />
      </AppWindow>
    </div>
  </div>
</section>
