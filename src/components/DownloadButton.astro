---
interface Props {
  size?: 'sm' | 'lg';
  showFinePrint?: boolean;
}

const { size = 'lg', showFinePrint = false } = Astro.props;
const href = 'https://github.com/Spectra-Player/releases/releases/latest';

const sizeClasses =
  size === 'lg'
    ? 'px-7 py-3 text-base'
    : 'px-4 py-1.5 text-sm';
---

<div class:list={['flex flex-col items-center gap-3', size === 'sm' && 'items-stretch']}>
  <a
    href={href}
    class:list={[
      'inline-flex items-center justify-center gap-2 rounded-full bg-white/90 font-medium text-ink-950 transition hover:bg-white',
      sizeClasses,
    ]}
  >
    <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
      <path
        d="M16.36 12.8c.02 2.3 2.01 3.06 2.03 3.07-.02.05-.32 1.09-1.05 2.16-.63.93-1.28 1.85-2.31 1.87-1.01.02-1.34-.6-2.5-.6s-1.52.58-2.48.62c-.99.04-1.75-1-2.39-1.92-1.3-1.88-2.29-5.32-.96-7.64.66-1.15 1.85-1.88 3.13-1.9.98-.02 1.9.66 2.5.66.6 0 1.72-.81 2.9-.69.49.02 1.88.2 2.77 1.5-.07.05-1.65.97-1.64 2.87ZM14.45 6.6c.53-.64.89-1.53.79-2.42-.76.03-1.69.51-2.24 1.15-.49.57-.93 1.48-.81 2.35.85.07 1.72-.43 2.26-1.08Z"
      />
    </svg>
    Download for macOS
  </a>
  {
    showFinePrint && (
      <p class="text-xs text-fg-faint">macOS 14+ · Apple Silicon &amp; Intel · Free during beta</p>
    )
  }
</div>
