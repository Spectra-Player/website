---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import AppWindow from './AppWindow.astro';

interface Props {
  eyebrow: string;
  title: string;
  copy: string;
  image: ImageMetadata;
  alt: string;
  reverse?: boolean;
}

const { eyebrow, title, copy, image, alt, reverse = false } = Astro.props;
---

<div class="mx-auto grid max-w-6xl items-center gap-10 px-6 py-16 lg:grid-cols-2 lg:gap-16">
  <div class:list={['max-w-lg', reverse && 'lg:order-2']}>
    <p class="text-sm font-medium tracking-wide text-fg-faint uppercase">{eyebrow}</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{title}</h2>
    <p class="mt-4 text-base leading-relaxed text-fg-muted">{copy}</p>
  </div>
  <div class:list={[reverse && 'lg:order-1']}>
    <AppWindow>
      <Image
        src={image}
        alt={alt}
        widths={[640, 960, 1400]}
        formats={['webp']}
        sizes="(max-width: 1024px) 100vw, 560px"
      />
    </AppWindow>
  </div>
</div>
